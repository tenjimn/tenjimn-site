---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

// Content Collections から記事取得 → order順にソート
const allPosts = await getCollection('blog');
const workArticles = allPosts
  .filter((post) => post.data.category === 'work')
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const lifeArticles = allPosts
  .filter((post) => post.data.category === 'life')
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

// Experience データ
const experiences = [
  {
    text: '10X.fm Podcast 出演 vol.1',
    url: 'https://podcasters.spotify.com/pod/show/10xfm/episodes/41-110X--GrowthSuccess-e1mkbfi/a-a8d5quk',
    extra: { text: 'vol.2', url: 'https://podcasters.spotify.com/pod/show/10xfm/episodes/36-Stailer2-e1m39ru' },
  },
  {
    text: '界隈.chat Podcast 出演',
    url: 'https://ysdyt.hatenablog.jp/entry/adventcalendar-10x-6th-anniversary',
  },
  {
    text: 'Yahoo! JAPAN Tech Blog 執筆',
    url: 'https://techblog.yahoo.co.jp/entry/2022040430273171/',
  },
  {
    text: 'Yahoo! JAPAN Tech Conference 2022 登壇',
    url: 'https://youtu.be/eAQ05phtxqw',
    extra: { text: 'レポート', url: 'https://levtech.jp/media/article/column/detail_66/' },
  },
  {
    text: 'Meety データアナリスト特集 掲載',
    url: 'https://meety.net/pickups/cdzzs6bof_s',
  },
  {
    text: '日本経済新聞 Data Science Fes 2019 登壇',
    url: 'https://dsfes.nikkei.co.jp/2019/report/sa/session2/',
  },
  {
    text: 'データ分析:ゆるふわキャリア相談会 主催',
    url: 'https://connpass.com/event/147298/',
  },
  {
    text: 'Wantedly キャリアインタビュー',
    url: 'https://t.co/XWugRxkWn6?amp=1',
  },
];
---

<Layout title="tenjimn.com" description="Work & Life — tenjimn">

  <!-- ====== Header ====== -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-[var(--color-border)]">
    <nav class="max-w-5xl mx-auto px-4 md:px-8 h-12 flex items-center justify-between">
      <a href="/" class="text-xs font-medium tracking-[0.15em] uppercase hover:opacity-50 transition-opacity duration-300">
        tenjimn
      </a>
      <div class="flex items-center gap-5 md:gap-6">
        <a href="#work" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">Work</a>
        <a href="#life" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">Life</a>
        <a href="#about" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">About</a>
        <a href="#contact" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">Contact</a>
      </div>
    </nav>
  </header>

  <!-- ====== Hero (ヘッダー画像背景) ====== -->
  <section class="hero-section relative min-h-[70vh] md:min-h-screen flex flex-col justify-center items-center px-4 md:px-8 overflow-hidden">
    <div class="hero-bg absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero-bg.jpeg');"></div>
    <div class="hero-overlay absolute inset-0"></div>
    <div class="text-center max-w-2xl relative z-10">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-light tracking-[-0.02em] leading-[1.1] animate-fade-in-up" style="font-family: 'Cormorant Garamond', serif;">
        tenjimn
      </h1>
    </div>
    <div class="absolute bottom-8 animate-bounce-slow z-10">
      <svg width="14" height="20" viewBox="0 0 14 20" fill="none" class="text-[var(--color-muted)]">
        <rect x="1" y="1" width="12" height="18" rx="6" stroke="currentColor" stroke-width="1"/>
        <circle cx="7" cy="6" r="1.5" fill="currentColor" class="animate-scroll-dot"/>
      </svg>
    </div>
  </section>

  <!-- ====== Work Section (灰色背景) ====== -->
  <section id="work" class="py-16 md:py-24 px-4 md:px-8 bg-[var(--color-bg-subtle)] border-t border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 md:mb-16">
        <h2 class="text-2xl md:text-3xl font-light tracking-[-0.01em]" style="font-family: 'Cormorant Garamond', serif;">Work</h2>
      </div>
      <div class="space-y-0">
        {workArticles.map((article) => (
          <a
            href={`/blog/${article.data.slug || article.slug}`}
            class="group block border-b border-[var(--color-border)] py-5 md:py-6 transition-all duration-500 hover:pl-3"
          >
            <div class="flex items-baseline justify-between gap-3 md:gap-6">
              <h3 class="text-sm md:text-base font-normal tracking-wide group-hover:tracking-wider transition-all duration-500">
                {article.data.title}
              </h3>
              <span class="w-3 h-px bg-[var(--color-muted)] group-hover:w-6 group-hover:bg-black transition-all duration-500 shrink-0"></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== Life Section (白色背景、画像カード) ====== -->
  <section id="life" class="py-16 md:py-24 px-4 md:px-8 border-t border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 md:mb-16">
        <h2 class="text-2xl md:text-3xl font-light tracking-[-0.01em]" style="font-family: 'Cormorant Garamond', serif;">Life</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
        {lifeArticles.map((article) => (
          <a
            href={`/blog/${article.data.slug || article.slug}`}
            class="life-card group relative block overflow-hidden rounded-sm transition-all duration-500"
          >
            {article.data.heroImage ? (
              <div class="life-card-inner relative">
                <div
                  class="life-card-bg absolute inset-0 bg-cover bg-center transition-all duration-700 group-hover:scale-105"
                  style={`background-image: url('${article.data.heroImage}');`}
                ></div>
                <div class="life-card-overlay absolute inset-0 transition-all duration-500"></div>
                <div class="relative z-10 p-4 md:p-6">
                  <h3 class="text-sm md:text-base font-normal tracking-wide text-gray-800 group-hover:text-black transition-all duration-500">
                    {article.data.title}
                  </h3>
                </div>
              </div>
            ) : (
              <div class="p-4 md:p-6 bg-gray-50">
                <h3 class="text-sm md:text-base font-normal tracking-wide group-hover:tracking-wider transition-all duration-500">
                  {article.data.title}
                </h3>
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== About Me Section (画像背景) ====== -->
  <section id="about" class="about-section relative py-16 md:py-24 px-4 md:px-8 bg-[var(--color-bg-subtle)] border-t border-[var(--color-border)] overflow-hidden">
    <div class="about-bg absolute inset-0 bg-cover bg-center" style="background-image: url('/images/about-bg.jpg');"></div>
    <div class="about-overlay absolute inset-0"></div>
    <div class="max-w-5xl mx-auto relative z-10">
      <div class="mb-10 md:mb-16">
        <h2 class="text-2xl md:text-3xl font-light tracking-[-0.01em]" style="font-family: 'Cormorant Garamond', serif;">About me</h2>
      </div>
      <div class="max-w-3xl">
        <p class="text-sm md:text-base text-[var(--color-secondary)] font-light leading-[2] tracking-wide">
          北海道生まれ・北海道育ち・北海道住み、可愛い娘がいる父親です。主にIT企業でデータやAI関連のお仕事をしています。これまで日産自動車・アクセンチュア・ZOZO・ヤフー・10X・LayerXに参画、その他個人で複数社のご支援など。
        </p>
      </div>
    </div>
  </section>

  <!-- ====== Experience Section (白色背景、箇条書き) ====== -->
  <section id="experience" class="py-16 md:py-24 px-4 md:px-8 border-t border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 md:mb-12">
        <h2 class="text-2xl md:text-3xl font-light tracking-[-0.01em]" style="font-family: 'Cormorant Garamond', serif;">Experience</h2>
      </div>
      <ul class="experience-list space-y-2">
        {experiences.map((exp) => (
          <li class="text-sm md:text-base font-light tracking-wide text-[var(--color-secondary)]">
            <a href={exp.url} target="_blank" rel="noopener noreferrer"
              class="hover:text-black transition-colors duration-300 border-b border-transparent hover:border-black">
              {exp.text}
            </a>
            {exp.extra && (
              <>
                <span class="text-[var(--color-muted)]"> / </span>
                <a href={exp.extra.url} target="_blank" rel="noopener noreferrer"
                  class="hover:text-black transition-colors duration-300 border-b border-transparent hover:border-black">
                  {exp.extra.text}
                </a>
              </>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ====== Contact / Footer (灰色背景) ====== -->
  <footer id="contact" class="py-16 md:py-24 px-4 md:px-8 bg-[var(--color-bg-subtle)] border-t border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-light tracking-[-0.01em] mb-6" style="font-family: 'Cormorant Garamond', serif;">Contact</h2>
          <div class="flex items-center gap-5">
            <!-- X (Twitter) -->
            <a href="https://x.com/tenjimn" target="_blank" rel="noopener noreferrer"
              class="text-[var(--color-secondary)] hover:text-black transition-colors duration-300" aria-label="X">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <!-- GitHub -->
            <a href="https://github.com/tenjimn" target="_blank" rel="noopener noreferrer"
              class="text-[var(--color-secondary)] hover:text-black transition-colors duration-300" aria-label="GitHub">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            </a>
            <!-- Instagram -->
            <a href="https://www.instagram.com/tenjimn/" target="_blank" rel="noopener noreferrer"
              class="text-[var(--color-secondary)] hover:text-black transition-colors duration-300" aria-label="Instagram">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <!-- Facebook -->
            <a href="https://www.facebook.com/daishi.tenjimbayashi/" target="_blank" rel="noopener noreferrer"
              class="text-[var(--color-secondary)] hover:text-black transition-colors duration-300" aria-label="Facebook">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>
        <p class="text-xs text-[var(--color-muted)] tracking-wider">&copy; tenjimn. All rights reserved.</p>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ====== Hero 背景 ====== */
  .hero-bg {
    opacity: 0.35;
    filter: grayscale(30%);
  }
  .hero-overlay {
    background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.65) 100%);
  }

  /* ====== Life Cards ====== */
  .life-card-inner {
    min-height: 100px;
  }
  .life-card-bg {
    opacity: 0.35;
    filter: grayscale(30%);
  }
  .life-card:hover .life-card-bg {
    opacity: 0.5;
    filter: grayscale(0%);
  }
  .life-card-overlay {
    background: linear-gradient(135deg, rgba(255,255,255,0.65) 0%, rgba(255,255,255,0.45) 100%);
  }
  .life-card:hover .life-card-overlay {
    background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.3) 100%);
  }

  /* ====== About Me 背景 ====== */
  .about-bg {
    opacity: 0.45;
    filter: grayscale(40%);
  }
  .about-overlay {
    background: linear-gradient(180deg, rgba(250,250,250,0.6) 0%, rgba(250,250,250,0.55) 50%, rgba(250,250,250,0.65) 100%);
  }

  /* ====== Experience 箇条書き ====== */
  .experience-list {
    list-style: disc;
    padding-left: 1.25rem;
  }
  .experience-list li::marker {
    color: var(--color-muted);
  }

  /* ====== Animations ====== */
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scroll-dot {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(6px); opacity: 0.3; }
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }
  .animate-fade-in-up { animation: fade-in-up 1s ease-out 0.3s both; }
  .animate-scroll-dot { animation: scroll-dot 2s ease-in-out infinite; }
  .animate-bounce-slow { animation: bounce-slow 2.5s ease-in-out infinite; }
</style>
