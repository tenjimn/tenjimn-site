---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug || post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout 
  title={`${post.data.title} | tenjimn`} 
  description={post.data.title}
  image={post.data.heroImage}
  ogType="article"
>

  <!-- ====== Header ====== -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-[var(--color-border)]">
    <nav class="max-w-3xl mx-auto px-4 md:px-8 h-12 flex items-center justify-between">
      <a href="/" class="text-xs font-medium tracking-[0.15em] uppercase hover:opacity-50 transition-opacity duration-300">
        tenjimn
      </a>
      <div class="flex items-center gap-5">
        <a href="/#work" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">Work</a>
        <a href="/#life" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">Life</a>
        <a href="/#about" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">About</a>
        <a href="/#contact" class="text-[10px] md:text-xs tracking-[0.1em] uppercase text-[var(--color-secondary)] hover:text-black transition-colors duration-300">Contact</a>
      </div>
    </nav>
  </header>

  <!-- ====== Article ====== -->
  <main class="pt-20 pb-16 md:pt-24 md:pb-24 px-4 md:px-8">
    <article class="max-w-2xl mx-auto">

      <!-- Title -->
      <header class="mb-8 md:mb-12">
        <p class="text-[10px] md:text-xs tracking-[0.15em] uppercase text-[var(--color-muted)] mb-3">
          {post.data.category}
        </p>
        <h1 class="text-xl md:text-2xl lg:text-3xl font-normal leading-[1.5] tracking-wide">
          {post.data.title}
        </h1>
      </header>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

    </article>
  </main>

  <!-- ====== Footer ====== -->
  <footer class="border-t border-[var(--color-border)] py-8 px-4 md:px-8">
    <div class="max-w-2xl mx-auto flex items-center justify-between">
      <a href="/" class="text-xs text-[var(--color-secondary)] hover:text-black transition-colors duration-300 tracking-wider">
        ← Back
      </a>
      <p class="text-[10px] text-[var(--color-muted)] tracking-wider">
        &copy; tenjimn
      </p>
    </div>
  </footer>

  <!-- Twitter/X 埋め込み -->
  <script async src="https://platform.twitter.com/widgets.js"></script>

  <!-- Instagram 埋め込み -->
  <script async src="//www.instagram.com/embed.js"></script>

</Layout>

<style>
  /* ====== 記事本文スタイル (yamotty.me 参考) ====== */
  .prose {
    font-size: 0.9375rem; /* ~15px (14px + 1pt) */
    line-height: 2;
    color: #333;
    letter-spacing: 0.02em;
  }

  .prose :global(h1) {
    font-size: 1.5rem;
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .prose :global(h2) {
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 500;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    color: #555;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.3s;
  }

  .prose :global(a:hover) {
    color: #000;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
    border-radius: 2px;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: #666;
    font-style: normal;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul) {
    list-style-type: disc;
  }

  .prose :global(ol) {
    list-style-type: decimal;
  }

  .prose :global(li) {
    margin-bottom: 0.35rem;
  }

  .prose :global(code) {
    font-size: 0.8rem;
    background: #f5f5f5;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .prose :global(pre) {
    background: #f8f8f8;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.8rem;
    line-height: 1.7;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.8rem;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    background: #fafafa;
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .prose {
      font-size: 0.9375rem;
    }
  }

  /* ====== Gallery Grid (Notion DB) ====== */
  .prose :global(.gallery-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }

  .prose :global(.gallery-item) {
    background: #f8f8f8;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-align: center;
    display: flex;
    flex-direction: column;
  }

  .prose :global(.gallery-item img) {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .prose :global(.gallery-caption) {
    font-size: 0.8rem;
    color: #555;
    margin: 0;
    padding: 0.6rem 0.75rem;
    line-height: 1.4;
  }

  /* ====== Twitter/X 埋め込み ====== */
  .prose :global(.twitter-tweet) {
    margin: 1.5rem auto !important;
    padding: 1rem !important;
    max-width: 550px;
  }
</style>
